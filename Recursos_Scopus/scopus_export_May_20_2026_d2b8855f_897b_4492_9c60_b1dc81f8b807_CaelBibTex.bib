	doi = {10.1109/RIVF68649.2025.11365222},
	url = {https://www.scopus.com/pages/publications/105034487913?origin=resultslist},
	abstract = {Parkinson's disease (PD) is a progressive neurodegenerative disorder that impairs motor and cognitive function, and electroencephalography has emerged as a practical modality to support diagnosis. We propose a subjectwise validated framework that couples rigorous preprocessing with explainable machine learning. Signals are denoised using FastICA with ICLabel to remove non-neural components, normalized, and partitioned into delta, theta, alpha, beta, and gamma bands. From each band, we extract complementary descriptors spanning statistical measures, entropy indices, and fractal dimensions, and train an XGBoost classifier on the resulting feature vectors. Model interpretability is achieved with SHAP using TreeExplainer, which quantifies the contribution of each descriptor to individual predictions and to the global decision rule. The fused feature set yields balanced, state-of-theart performance, achieving 97.71 % accuracy, 98.13% sensitivity, and 97.29 % specificity for the two-class control versus PD task, and 97.82% accuracy, 97.96 % sensitivity, and 98.87 % specificity for the three-class control, ON, and OFF task. SHAP attributions indicate that band-limited statistics and entropy measures drive the control versus PD contrast, whereas multiscale complexity, as captured by fractal descriptors, is most discriminative for medication state. These findings demonstrate that accurate and transparent EEG-based support for PD diagnosis is feasible within a single, cohesive pipeline. © 2025 IEEE.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@CONFERENCE{Kanimozhi2025642,
	author = {Kanimozhi, J.K. and Bavya, G. and Kalyanasundaram, P. and Anitha, P. and Geetha, R. and Loganathan, E.},
	title = {Evaluating the Effectiveness of Random Forest + XGBoost versus Support Vector Machines in Achieving High Accuracy and Precision for Breast Cancer Classification},
