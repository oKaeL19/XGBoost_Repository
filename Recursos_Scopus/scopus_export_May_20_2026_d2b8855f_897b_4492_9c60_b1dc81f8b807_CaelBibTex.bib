@CONFERENCE{Li202573,
	author = {Li, Han and Zhao, Yongqiang and Tan, Weihao and Wang, Huaqing and Li, Jiaxing and Lei, Ting},
	title = {Research on Power Frequency Waveform Classification for Transmission Lines Based on a Cascaded XGBoost Model},
	year = {2025},
	journal = {2025 6th International Conference on Smart Grid and Energy Engineering, SGEE 2025},
	pages = {73 - 79},
	doi = {10.1109/SGEE68429.2025.11385589},
	url = {https://www.scopus.com/pages/publications/105034724051?origin=resultslist},
	abstract = {Accurate classification of power frequency waveforms is critical for transmission line fault location. While deep learning models (LSTM, CNN) show promise on idealized data, their practical application is constrained by three major challenges: dependency on simulated data, poor performance on imbalanced real-world datasets, and high computational costs requiring GPU resources. To address these limitations, this paper proposes a cascaded XGBoost model specifically designed for real-grid environments. Our approach decomposes the seven-class waveform classification task into a sequence of binary decisions with tailored feature engineering, enabling effective learning from actual grid data with inherent imbalance. Experimental results demonstrate superior performance over conventional deep learning models, achieving 94.1% overall accuracy, 95.0% macro-average F1-score, and 94.1% weighted-average F1-score while completing training approximately 109 times faster than the LSTM model and 19 times faster than the CNN model. The model's computational efficiency and reliability on CPU-only systems make it particularly suitable for resource-constrained fault diagnosis applications. © 2025 IEEE.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@CONFERENCE{Ajaani2025,
	author = {Ajaani, Mouna and Radouane, Mohamed},
	title = {A Hybrid Approach Using CNN Feature Extraction and SVM/XGBoost for Lung Nodule Classification},
	year = {2025},
	journal = {SITA 2025 - 15th International Conference on Intelligent Systems: Theories and Applications},
	pages = {},
	doi = {10.1109/SITA67914.2025.11273552},
	url = {https://www.scopus.com/pages/publications/105030467596?origin=resultslist},
	abstract = {Early detection of lung cancer is highly beneficial for patient survival. This paper proposes a hybrid deep learning diagnostic pipeline for pulmonary nodules in chest CT. We constructed a new balanced dataset in which three publicly available CT datasets are incorporated: LUNA16, Data Science Bowl 2018 and a small fraction from 100 patients in LIDC-IDRI. After preprocessing and patch extraction, data were categorized into nodule and non-nodule classes. To extract features, we used six pretrained CNN architectures (ResNet50, VGG16, MobileNetV2, EfficientNetB0, DenseNet121, and InceptionV3). For feature training, traditional classifiers Support Vector Machines (SVM), and XGBoost were then utilized. We employed data augmentation techniques to improve model generalization and prevent overfitting. The most accurate pipeline we encountered utilized ResNet50 with SVM and reached 98 % accuracy. These results demonstrate the benefits of using deep feature extraction alongside conventional machine-learning classifiers, and highlight the effectiveness and robustness of an easily adoptable approach to lung nodule detection in medical imaging. ©2025 IEEE.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1}
}

@CONFERENCE{Juliandri202418,
