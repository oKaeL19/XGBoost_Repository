@ARTICLE{Samadi202511351,
	author = {Samadi, Hanan and Hassanpour, Jafar and Rostami, Jamal},
	title = {Assessment of the Relationship Between Rock Mass Classification Systems Using Hybrid XGBoost Algorithms: Insights from the Mechanized Tunnelling Project Database},
