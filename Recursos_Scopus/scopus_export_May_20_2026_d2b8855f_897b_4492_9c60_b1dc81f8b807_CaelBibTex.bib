@CONFERENCE{Al-Qahri202591,
	author = {Al-Qahri, Muhammad Ali Akbar and Saepudin, Deni},
	title = {Classification of Stocks with Potential to Reach Minimum Price Levels on the Indonesian Stock Exchange using Support Vector Machine (SVM) and eXtreme Gradient Boosting (XGBoost)},
	year = {2025},
	journal = {2025 International Conference on Data Science and Its Applications, ICoDSA 2025},
	pages = {91 - 96},
	doi = {10.1109/ICoDSA67155.2025.11157479},
	url = {https://www.scopus.com/pages/publications/105018111110?origin=resultslist},
	abstract = {In the regular trading market of the Indonesian Stock Exchange (IDX), stocks are commonly traded at prices above 50 IDR per share. However, when a stock reaches this minimum price, investors perceive it as a negative signal, leading to reduced market interest and liquidity. Such declines, linked to weak fundamentals, poor financial performance, and negative sentiment, are critical for analysis. This study examines six financial indicators - Price-To-Book Value (PBV), Price-To-Tangible Book Value (PTBV), Current Ratio (CR), Quick Ratio (QR), Debt-To-Equity Ratio (DER), and Working Capital Ratio (WCR) - over the last four quarters to predict stock movements to this critical threshold. These indicators, selected for their connection to firm performance and financial health, form a robust foundation for analysis. Feature selection using Cramér's V correlation improves model accuracy by identifying the most influential factors. The research employs eXtreme Gradient Boosting (XGBoost) and Support Vector Machine (SVM), which show distinct strengths in predicting stock performance. SVM achieved an accuracy of 71%, excelling in recall (76%) and F1-score (72%) for stocks above the 50 IDR threshold. XGBoost, with 70% accuracy, showed balanced performance across precision, recall, and F1-score, highlighting its robustness in classification tasks. Notably, Quick Ratio (QR) emerged as a key factor in both models, reflecting its importance in investor decision-making by indicating liquidity. This research contributes to predicting stocks reaching critical price thresholds in the Indonesian financial market. The findings underscore the value of combining financial indicators with machine learning to enhance decision-making. These insights are valuable for investors and policymakers, offering a framework to identify at-risk stocks and optimize strategies in dynamic markets.  © 2025 IEEE.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@CONFERENCE{Primandari2025,
