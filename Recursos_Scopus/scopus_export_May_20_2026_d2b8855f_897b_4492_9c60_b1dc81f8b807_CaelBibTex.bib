@CONFERENCE{Vishnoi2025549,
	author = {Vishnoi, Swati and Pareek, Meenakshi},
	title = {Boosted Ensemble Classification of Landsat 8 Imagery Over Nainital Region Using Fuzzy C-Means and XGBoost},
	year = {2025},
	journal = {Proceedings of the 2025 14th International Conference on System Modeling and Advancement in Research Trends, SMART 2025},
	pages = {549 - 553},
	doi = {10.1109/SMART66937.2025.11389590},
	url = {https://www.scopus.com/pages/publications/105035368802?origin=resultslist},
	abstract = {Classifying land cover in mountainous and other variable terrain is one of the more difficult tasks in remote sensing. This paper proposes a hybrid ensemble learning approach for the classification of Landsat 8 imagery of Nainital. The hybrid uses Fuzzy C-Means clustering and Extreme Gradient Boosting based (XGBoost). In the first step, the FCM process recognizes that the satellite data contain fuzzy and mixed pixels, which are then assigned a 'soft membership' for each land cover category. The 'soft memberships' are then input into an XGBoost classifier, which will learn how to classify these categories. Boosting will also help further train and improve the boosted model's performance, by concentrating on cases where the categories are difficult to classify. These experimental outcomes also reaffirm that the proposed hybrid classifier strategy will work better in classification related to overall accuracy (93.67 percent), the F1-score (0.91), and recall accuracy (0.89), when compared to previous classifiers, such as Random Forests, Support Vector Machines, and FCM. Furthermore, it generally performs well in cases where mixed pixels are present and in complex arrangements, thus adaptable to high-resolution land cover mapping in similar areas. © 2025 IEEE.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

