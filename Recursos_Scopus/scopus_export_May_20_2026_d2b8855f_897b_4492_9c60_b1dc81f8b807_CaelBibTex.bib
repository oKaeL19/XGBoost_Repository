	author = {Abdelghani, Rana M. and Morsi, Iman and Taha, Taha El-Sayed and El-Shafie, Walid and Kashyout, Abd El-Hady B.},
	title = {Smart Image Processing and Classification of Hematite SEM Images: A Comparative Study of Neural Networks, SVM, and XGBoost},
	year = {2025},
	journal = {2025 International Conference on Future Telecommunications and Artificial Intelligence, IC-FTAI 2025 - Proceedings},
	pages = {},
	doi = {10.1109/IC-FTAI67960.2025.11384623},
	url = {https://www.scopus.com/pages/publications/105034849213?origin=resultslist},
	abstract = {The classification and identification of material types from Scanning Electron Microscopy (SEM) images remain critical tasks in material science are often limited by the subjectivity and time constraints of manual human analysis. Recent advances in image processing and artificial intelligence (AI) have enabled more objective, automated, and scalable analysis of complex microstructural data. In this paper a fully automated image analysis for the classification of hematite samples synthesized under six different conditions is presented, leveraging state-of-the-art machine learning algorithms to accurately distinguish and differentiate between material types based exclusively on SEM figures. The methodology participates data preprocessing, feature extraction using Histogram of Oriented Gradients (HOG), and three powerful supervised AI models: Support Vector Machine (SVM), Extreme Gradient Boosting (XGBoost), and a MultiLayer Perceptron (Neural Network). Each model was trained, validated, and tested using a comprehensive dataset totaling 3,224 SEM images including hundreds of augmented SEM images for each material sort, confirming robustness and generalizability. The performance of each classifier was quantitatively estimated using multiple statistical metrics including accuracy, confusion matrix, Receiver Operating Characteristic (ROC) analysis, and error measures such as RMS, NRMS, and R<sup>2</sup> score to permit a comprehensive comparison.  © 2025 IEEE.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@CONFERENCE{Sitanggang2025,
