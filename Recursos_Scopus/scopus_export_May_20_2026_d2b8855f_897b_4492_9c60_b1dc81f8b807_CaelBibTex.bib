	title = {Comparison of Multi-Layer Perceptron and XGBoost for Urgency Classification of Student Complaints Using IndoBERT Embeddings},
	year = {2026},
	journal = {Proceeding - ISIBER 2026: International Seminar on Intelligent Business and Edge-Computing Research},
	pages = {350 - 354},
	doi = {10.1109/ISIBER68248.2026.11469915},
	url = {https://www.scopus.com/pages/publications/105037638364?origin=resultslist},
	abstract = {Student complaint management systems play an important role in improving service quality in higher education institutions. However, the increasing volume of complaints submitted in free-text form makes manual urgency assessment inefficient and subjective, potentially delaying responses to critical issues. This study presents a comparative analysis of Multi-Layer Perceptron (MLP) and XGBoost for classifying the urgency level of student complaints using IndoBERT embeddings as semantic features. Complaint texts are transformed into contextual numerical representations using a pre-trained IndoBERT model, while MLP and XGBoost are employed as classification algorithms. Urgency levels are categorized into Low, Medium, and High based on academic impact and response priority. Experiments are conducted using real student complaint data collected from the Faculty of Medicine and Health Sciences, Universitas Warmadewa. Model performance is evaluated using accuracy and macro-averaged precision, recall, and F1-score. The results indicate that both models are capable of performing urgency classification effectively; however, XGBoost consistently outperforms MLP across all evaluation metrics. Confusion matrix analysis further demonstrates that XGBoost provides more reliable identification of High urgency complaints. These findings suggest that combining transformer-based embeddings with ensemble learning methods offers a robust approach for automated urgency classification in student complaint management systems. © 2026 IEEE.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

