@ARTICLE{Ye2022,
	author = {Ye, Xiaohong and Huang, Yuanqi and Lu, Qiang},
	title = {Automatic Multichannel Electrocardiogram Record Classification Using XGBoost Fusion Model},
	year = {2022},
