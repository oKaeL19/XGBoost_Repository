@ARTICLE{Wang202110,
	author = {Wang, Zichao and Jin, Yanrui and Zhao, Liqun and Liu, Chengliang},
	title = {A heart sound classification method based on joint decision of extreme gradient boosting and deep neural network},
	year = {2021},
	journal = {Sheng wu yi xue gong cheng xue za zhi = Journal of biomedical engineering = Shengwu yixue gongchengxue zazhi},
	volume = {38},
