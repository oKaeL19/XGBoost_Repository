@ARTICLE{Fitrieyatul Hikmah20251272,
	author = {Fitrieyatul Hikmah, Nada and Setiawan, Rachmad and Amalia, Rima and Syulthoni, Zain Budi and Nugroho, Dwi Oktavianto Wahyu and Syakir, Mu’Afa Ali},
	title = {A Mattress-Integrated ECG System for Home Detection of Obstructive Sleep Apnea Through HRV Analysis Using Wavelet Transform and XGBoost Classification},
	year = {2025},
	journal = {Journal of Electronics, Electromedical Engineering, and Medical Informatics},
	volume = {7},
